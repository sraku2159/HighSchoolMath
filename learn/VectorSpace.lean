import Mathlib

-- # ベクトル空間の例（VectorSpace.md 対応）

-- ----------------------------------------------------------------
-- § 1. よく知られた型の instance を確認する
-- ----------------------------------------------------------------

-- ℝ 上のベクトル空間
#check (inferInstance : Module ℝ ℝ)           -- ℝ は自分自身の上のベクトル空間
#check (inferInstance : Module ℝ (ℝ × ℝ))     -- ℝ² は ℝ 上のベクトル空間
#check (inferInstance : Module ℝ (EuclideanSpace ℝ (Fin 3)))  -- ℝ³

-- ℚ 上のベクトル空間
#check (inferInstance : Module ℚ ℚ)           -- ℚ は ℚ 上のベクトル空間

-- ----------------------------------------------------------------
-- § 2. 自前で Module instance を定義する：ℤ 係数の ℤ² 加群
-- (ℤ × ℤ) は ℤ 上の加群（ℤ は体でないので厳密にはベクトル空間ではない）
-- ----------------------------------------------------------------

-- ℤ × ℤ の ℤ-加群構造を確認（Mathlib に既にある）
#check (inferInstance : Module ℤ (ℤ × ℤ))

-- ----------------------------------------------------------------
-- § 3. 自前で ℝ 上のベクトル空間を定義する：Option ℝ への拡張
-- 実用例として ℝ² のスカラー乗法を手動で確認
-- ----------------------------------------------------------------

-- ℝ² のスカラー倍の計算例
example : (2 : ℝ) • ((3, 4) : ℝ × ℝ) = (6, 8) := by norm_num

-- ----------------------------------------------------------------
-- § 4. 自前で Module instance を定義する：Unit（自明な加群）
-- Unit は任意の半環上の自明な加群
-- ----------------------------------------------------------------

instance : Module ℝ Unit where
  smul _ _ := ()
  one_smul _      := rfl
  mul_smul _ _ _  := rfl
  smul_zero _     := rfl
  smul_add _ _ _  := rfl
  add_smul _ _ _  := rfl
  zero_smul _     := rfl
